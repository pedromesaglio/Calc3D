# ============================================
# CALC3D - Variables de Entorno
# ============================================
# Copia este archivo como .env y configura los valores apropiados

# ── Entorno ──
ENVIRONMENT=development  # development | production

# ── Stripe (Procesador de pagos internacional) ──
# Obten tus claves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# IDs de precios de Stripe (crea productos en: https://dashboard.stripe.com/products)
STRIPE_PRICE_ID_PRO=price_your_pro_plan_price_id
STRIPE_PRICE_ID_BUSINESS=price_your_business_plan_price_id

# ── Mercado Pago (Procesador de pagos para Latinoamérica) ──
# Obten tus credenciales en: https://www.mercadopago.com.ar/developers/panel
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token_here
MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key_here
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret_here

# IDs de planes de Mercado Pago
MERCADOPAGO_PLAN_ID_PRO=your_pro_plan_id
MERCADOPAGO_PLAN_ID_BUSINESS=your_business_plan_id

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ── Logging ──
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=calc3d.log

# ── URLs (para webhooks y callbacks) ──
BASE_URL=http://localhost:8000  # Cambia esto en producción

# ── Base de Datos ──
# SQLite por defecto, se crea automáticamente
DATABASE_PATH=calc3d.db

# ============================================
# NOTAS DE CONFIGURACIÓN
# ============================================
#
# STRIPE:
# 1. Crea una cuenta en https://stripe.com
# 2. Obtén tus API keys en el dashboard
# 3. Crea productos y precios para tus planes
# 4. Configura los webhooks apuntando a: https://tu-dominio.com/webhooks/stripe
# 5. Eventos a escuchar:
#    - checkout.session.completed
#    - customer.subscription.created
#    - customer.subscription.updated
#    - customer.subscription.deleted
#    - invoice.payment_succeeded
#    - invoice.payment_failed
#
# MERCADO PAGO:
# 1. Crea una cuenta en https://www.mercadopago.com
# 2. Ve a Developers > Tus credenciales
# 3. Obtén el Access Token (producción o prueba)
# 4. Configura webhooks apuntando a: https://tu-dominio.com/webhooks/mercadopago
#
# PRODUCCIÓN:
# - Usa ENVIRONMENT=production
# - Configura BASE_URL con tu dominio real
# - Usa claves de producción (no test)
# - Configura HTTPS para webhooks
# - Considera usar un servicio de logging externo
#
